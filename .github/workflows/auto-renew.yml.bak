name: FreeXCraft Auto Renewal

on:
  workflow_dispatch:  # 手动触发
  schedule:
    # 每天北京时间 12:00 运行 (UTC+8 对应 04:00 UTC)
    - cron: '0 4 * * *'

jobs:
  renew:
    runs-on: ubuntu-latest
    
    steps:
    - name: Checkout repository
      uses: actions/checkout@v4
    
    - name: Set up Python
      uses: actions/setup-python@v5
      with:
        python-version: '3.10'
    
    - name: Install dependencies
      run: |
        pip install requests
        pip install python-dotenv  # 可选，用于本地测试
    
    - name: Run renewal script
      env:
        FXC_EMAIL: ${{ secrets.FXC_EMAIL }}
        FXC_PASS: ${{ secrets.FXC_PASS }}
        FXC_SERVER_ID: ${{ secrets.FXC_SERVER_ID }}
        TG_BOT_TOKEN: ${{ secrets.TG_BOT_TOKEN }}
        TG_USER_ID: ${{ secrets.TG_USER_ID }}
        # 可选：如果需要代理，可以配置以下环境变量
        # PROXY_URL: ${{ secrets.PROXY_URL }}
        # PROXY_USER: ${{ secrets.PROXY_USER }}
        # PROXY_PASS: ${{ secrets.PROXY_PASS }}
      run: |
        python freexcraft_renewal.py
